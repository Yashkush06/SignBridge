exports[`Card snapshots (both themes) > renders a card with header/content in dark 1`] = `"<div class="dark"><div class="rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)] text-[var(--fg)] shadow-xs"><div class="flex flex-col space-y-1.5 p-6"><h3 class="font-semibold leading-none tracking-tight">Session summary</h3><p class="text-sm text-[var(--fg-secondary)]">Recent translation activity</p></div><div class="p-6 pt-0">Body content</div></div></div>"`;

